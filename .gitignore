# -----------------------
# Python / Django
# -----------------------
venv/                   # Python virtual environment
__pycache__/            # Python cache
*.pyc
*.pyo
*.pyd
db.sqlite3               # SQLite database (ignore if switching to Postgres)
*.sqlite3-journal        # SQLite temp files
.env                     # Django environment variables

# -----------------------
# React / Node
# -----------------------
node_modules/            # Node modules
build/                   # React build output
.env.local               # React environment variables
.env.development
.env.production

# -----------------------
# IDE / OS files
# -----------------------
.vscode/                 # VSCode workspace settings
.DS_Store                # macOS
Thumbs.db                # Windows
*.log                    # log files

# -----------------------
# Optional extras
# -----------------------
coverage/                # test coverage
*.egg-info/              # Python packaging
pip-wheel-metadata/      
node_modules
